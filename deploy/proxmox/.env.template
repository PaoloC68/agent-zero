# Agent Zero — Environment Variables
# Copy to: /opt/agent-zero/.env
# chmod 600 /opt/agent-zero/.env
#
# Fill in all values before starting the container.

# ── Agent Zero built-in auth ──────────────────────────────────────────────────
AUTH_LOGIN=
AUTH_PASSWORD=

# ── Agent Zero config ─────────────────────────────────────────────────────────
A0_BASE_URL=https://helpa0.com

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPINFRA_API_KEY=
NEBIUS_API_KEY=
AWS_BEARER_TOKEN_BEDROCK=

# Aliases expected by Agent Zero's key resolution logic
API_KEY_GOOGLE=${GEMINI_API_KEY}
API_KEY_BEDROCK=${AWS_BEARER_TOKEN_BEDROCK}
API_KEY_DEEPINFRA=${DEEPINFRA_API_KEY}

# ── Tool / search APIs ────────────────────────────────────────────────────────
TAVILY_API_KEY=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
CONTEXT7_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Integrations ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
LANGSMITH_API_KEY=

# ── GitHub (for GHCR image pull + gitops) ────────────────────────────────────
GITHUB_PAT=
GHCR_PAT=

# ── Cisco Guard / Skill Scanner ───────────────────────────────────────────────
SKILL_SCANNER_LLM_API_KEY=
SKILL_SCANNER_LLM_MODEL=
